// ---- Zero-touch MQTT enrollment (optional) ----
// A fresh puck has no MQTT password in NVS. If ENROLL_URL/ENROLL_TOKEN are set, instead of asking the
// user to type one, the puck self-provisions: once Wi-Fi + the clock are up it generates a random
// password, POSTs {"code","pw"} over HTTPS to ENROLL_URL with an "Authorization: Bearer ENROLL_TOKEN"
// header; the droplet registers it in Mosquitto (mosquitto_passwd) and the puck stores it in NVS and
// connects — nobody ever types an MQTT password. Blank ENROLL_URL = off (use the captive-portal field).
// The TOKEN only authorizes ENROLLMENT (not message traffic) and it ends up in the binary, so
// rate-limit it server-side and rotate it once your fleet is provisioned. HTTPS is verified against
// MQTT_CA_CERT above (the endpoint sits on your droplet behind Caddy). Server side + flow:
// tools/enroll-server.py and tools/OTA-SETUP.md ("Zero-touch enrollment").
// Must match the token configured on the enroll server. Generate one with: openssl rand -hex 32
#define ENROLL_URL    ""   // e.g. "https://__FW_HOST__/enroll"  ("" = no self-enroll)
#define ENROLL_TOKEN  ""   // shared enroll secret (server checks it); blank when ENROLL_URL is blank

// ---- OTA firmware updates ----
// Over-the-air updates: each puck polls a small JSON manifest over HTTPS (boot + every
// OTA_POLL_HOURS), can be nudged instantly via the MQTT broadcast topic, or checked from the
// Settings screen; when the manifest's version is greater than FW_VERSION it offers the update
// on-screen (Update / Later) and, on confirm, flashes the inactive OTA slot and reboots.
// The manifest + .bin are served over HTTPS from your droplet (Caddy) — its Let's Encrypt cert
// validates against MQTT_CA_CERT above, so no extra CA is needed.
// FW_VERSION is defined in src/version.h (tracked separately so tools/release.sh can bump+commit it
// while this config.h — which holds secrets — stays gitignored).
#define OTA_MANIFEST_URL  "https://__FW_HOST__/planepuck/version.json"  // "" = OTA off
#define OTA_POLL_HOURS    24                                         // auto-poll cadence in hours (0 = no auto-poll; rely on Settings button + push)
#define OTA_PUSH_TOPIC    "puck/all/ota"                             // MQTT "re-check now" broadcast nudge
#define OTA_BIN_BASE      "https://__FW_HOST__/planepuck/firmware-v"  // targeted/picked flash: base + <ver> + ".bin"
#define OTA_VERSIONS_URL  "https://__FW_HOST__/planepuck/versions.json" // list of installable versions (on-device picker)
// DEPRECATED + UNUSED: the test/RC channel now arrives as an authenticated, retained MQTT marker
// (fleet/channel/<code>, operator-set) instead of this public URL — so device codes never go public.
#define OTA_TEST_URL      "https://__FW_HOST__/planepuck/test-devices.json" // (unused; kept so an existing config.h stays in sync)

// ---- Time ----
// Timezone is also chosen on-device during Wi-Fi setup; this is the default
// until you pick one there. POSIX TZ string (Pacific shown).
#define TZ_STRING   "PST8PDT,M3.2.0,M11.1.0"
#define NTP_SERVER  "pool.ntp.org"

// ---- Clock / screensaver / world clock ----
#define LAUNCHER_IDLE_MS       60000UL   // home screen auto-opens the Clock after this much idle time
#define CLOCK_DRIFT_PERIOD_MS  45000UL   // anti-burn-in: shift the clock block this often
#define CLOCK_DRIFT_MAX_PX     14        // max +/- drift from center (X and Y) — keeps it on-screen
#define MAX_WORLD_CITIES       4         // world-clock rows under the local time (cities chosen in Settings)
#define MAX_WEATHER_CITIES     4         // Weather app shows up to this many cities, equally divided (Settings)

// ---- Weather (Open-Meteo, no API key) ----
// Location is auto-detected by IP on first use; these are only a fallback if
// detection fails (default: San Francisco).
#define WEATHER_UNITS_F  1            // default units: 1 = Fahrenheit/mph, 0 = Celsius/km-h (override on-device in Settings)
#define WEATHER_LAT      "37.77"
#define WEATHER_LON      "-122.42"
#define WEATHER_CITY     "San Francisco"

// ---- Flight tracking (adsb.lol, no API key) ----
#define FLIGHT_RADIUS_NM  30          // search radius around your location (nautical miles)

// ---- Flight routes (OpenSky Network; optional, free) ----
// Origin/destination derived from each aircraft's actual tracked movement (accurate, unlike the
// free static route DBs). Create a free account at opensky-network.org, then an API client under
// Account -> "API clients" to get a client id + secret. Blank = routes show "route unknown".
// NOTE: OpenSky only has COMPLETED flights, so a plane still en route shows its most recent
// finished leg, not the live destination; a just-landed or looked-up flight shows correctly.
#define OPENSKY_CLIENT_ID      ""
#define OPENSKY_CLIENT_SECRET  ""

// ---- Compass radar (heading-up rotation; needs a magnetometer) ----
// The Flight radar rotates to heading-up only on units that actually have a
// magnetometer (auto-detected at boot). Two correction knobs, both applied to the
// computed heading:
//   HEADING_OFFSET_DEG  - fixes a device-axis mismatch. If, after a figure-8 cal, the
//                         "N" marker doesn't point at true north, nudge this until it does.
//   MAG_DECLINATION_DEG - magnetic-to-true correction for YOUR area (e.g. roughly +13 in
//                         the US west, negative in the east; 0 = ignore, fine for nearby use).
#define HEADING_OFFSET_DEG    0
#define MAG_DECLINATION_DEG   0

// ---- Brightness (0-255) ----
#define BRIGHT_DAY    180
#define BRIGHT_NIGHT  64        // night level (also the sensor's dark-room floor); raised so sensor-less units aren't too dim

// Deep idle-dim: after IDLE_DIM_SEC with no touch, drop below the normal level (a third tier on top
// of the 8s wake-boost + the normal day/night level). With the light sensor present the deep level
// scales with ambient; without it, a fixed level that's lower at night.
#define IDLE_DIM_SEC        120       // seconds of no touch before the deep idle-dim kicks in
#define BRIGHT_IDLE_DAY     40        // deep-idle level, daytime / sensor absent
#define BRIGHT_IDLE_NIGHT   32        // deep-idle level, night (lower than day, but still readable)
#define IDLE_DIM_SCALE_PCT  35        // sensor present: deep-idle target = this % of the ambient target

// Night window (24h): night is before DAY_START or at/after NIGHT_START
#define DAY_START_HOUR    7
#define NIGHT_START_HOUR  22

// ---- Ambient light sensor (CoreS3 LTR-553) ----
// The sensor is AUTO-DETECTED at boot (probed over I2C). If present, brightness follows real room
// light; if absent (e.g. the CoreS3 SE, which has no LTR-553), the time-of-day schedule is used.
// USE_LIGHT_SENSOR is no longer the gate (kept for reference). Set FORCE_NO_LIGHT_SENSOR=1 to ignore
// the sensor even when present (force the time-of-day schedule).
#define USE_LIGHT_SENSOR       0
#define FORCE_NO_LIGHT_SENSOR  0
// Raw CH0 ambient readings that map to the brightness range (tune to taste):
//   at/below LUX_DARK -> BRIGHT_NIGHT,  at/above LUX_BRIGHT -> BRIGHT_DAY
#define LUX_DARK      5
#define LUX_BRIGHT    400
