#pragma once
#include "version.h"            // FW_VERSION lives in version.h (tracked)

// ============================================================
//  TEMPLATE — copy this file to src/config.h (which is gitignored) and fill in your values:
//  the OpenSky client id/secret below, and your server hosts — replace the __MQTT_HOST__ and
//  __FW_HOST__ placeholders with your broker domain and firmware-host domain. (CI reconstructs
//  config.h from this file and fills those placeholders from the MQTT_HOST / FW_HOST repo secrets,
//  so the real hosts never live in the tracked source.) Build uses src/config.h, never this .example.
// ============================================================
//  EDIT THIS FILE to configure your puck. All optional —
//  leave blank to run fully offline (Clock shows local time,
//  Emoji runs in local demo mode with beep + screen feedback).
// ============================================================

// ---- Wi-Fi ----
// Normally you set Wi-Fi ON THE DEVICE at first boot (it opens a setup hotspot).
// These are optional fallback defaults; leave blank to provision on-device.
#define WIFI_SSID   ""
#define WIFI_PASS   ""

// ---- MQTT broker (friends emoji messaging) ----
// Point this at YOUR broker. For your private Mosquitto, MQTT_HOST is the DOMAIN its TLS
// cert is issued for (NOT an IP), with MQTT_TLS 1 / port 8883. For a quick local/plain test,
// set MQTT_TLS 0 and MQTT_PORT 1883. Blank MQTT_HOST = MQTT off (device runs fully offline).
#define MQTT_HOST   "__MQTT_HOST__"    // your broker domain (must match the TLS cert hostname); CI fills it from the MQTT_HOST secret
#define MQTT_PORT   8883               // 8883 = TLS, 1883 = plain
#define MQTT_TLS    1                  // 1 = TLS, verify broker via MQTT_CA_CERT; 0 = plain
#define MQTT_USER   ""                 // unused: the MQTT username is the device's friend code
#define MQTT_PASS   ""                 // leave blank: set the per-device password ON THE DEVICE (NVS)
#define GROUP_ID    "planepuck-demo"   // deprecated: emoji now uses the friends list, not this group
#define DEVICE_ID   "puck-a"           // MQTT client-id prefix (a unique per-chip suffix is appended)

