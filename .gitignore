.vscode/ipch

# secrets / local config — config.h carries the OpenSky client secret; keep it untracked.
# Copy config.h.example -> config.h and fill in secrets (config.h.example IS tracked).
src/config.h
*.pem
*.key
*.secret

# CI SSH deploy keypair — the private half must NEVER be committed
planepuck-deploy
planepuck-deploy.pub
deploy_key
deploy_key.pub

# python bytecode from local tooling (tools/*.py)
__pycache__/
*.pyc

# built firmware images embed the compiled-in secrets (OpenSky key, enroll token) — never commit them
*-merged.bin
*.bin

# Claude Code local session data
.claude/

# fleet device->group map (device codes = MQTT usernames; keep out of the public repo)
tools/fleet-groups.json
